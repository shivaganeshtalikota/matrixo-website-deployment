# ---------------------------------------------------------
# DevAgentic 1.0 Automated Email System Configuration
# ---------------------------------------------------------

# 1. Google Sheets Integration (Service Account)
# The email of your Google Service Account
GOOGLE_CLIENT_EMAIL=your-service-account-email@your-project-id.iam.gserviceaccount.com

# The private key of your Google Service Account (MUST include \n or real newlines)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour\nPrivate\nKey\n-----END PRIVATE KEY-----\n"

# The ID of your target Google Sheet (found in the URL)
GOOGLE_SHEET_ID=your-google-sheet-id-here

# 2. Nodemailer / SMTP Configuration
# Your SMTP Server (e.g., smtp.gmail.com)
SMTP_HOST=smtp.gmail.com
# Port (usually 465 for secure, or 587)
SMTP_PORT=465
# Your SMTP email address
SMTP_USER=your-email@gmail.com
# Your App Password (not your normal email password if using Gmail)
SMTP_PASS=your-app-password
# The "From" display name and email address
SMTP_FROM="matriXO Events <events@matrixo.in>"

# 3. Security (Optional, used if you rely on the API polling endpoint)
CRON_SECRET=your-random-secret-string
