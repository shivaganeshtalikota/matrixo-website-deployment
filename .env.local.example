# Firebase Configuration
# Copy this to .env.local and fill in your values
# Also add these to Vercel Environment Variables
# For beta deployment, set NEXT_PUBLIC_SITE_MODE=beta and use *_BETA overrides when needed.

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_auth_domain
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_storage_bucket
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Main-site Firebase overrides (recommended for matrixo.in)
NEXT_PUBLIC_FIREBASE_API_KEY_MAIN=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN_MAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID_MAIN=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET_MAIN=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID_MAIN=
NEXT_PUBLIC_FIREBASE_APP_ID_MAIN=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID_MAIN=

# Beta-site Firebase overrides (used only when NEXT_PUBLIC_SITE_MODE=beta)
# NEXT_PUBLIC_SITE_MODE=beta
NEXT_PUBLIC_FIREBASE_API_KEY_BETA=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN_BETA=
NEXT_PUBLIC_FIREBASE_PROJECT_ID_BETA=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET_BETA=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID_BETA=
NEXT_PUBLIC_FIREBASE_APP_ID_BETA=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID_BETA=

# Firebase Auth Google Sign-in authorized domains should include:
# - beta.matrixo.in
# - matrixo.in
# - localhost

# Event branding / payment assets
NEXT_PUBLIC_DEVAGENTS_UPI_ID=your_upi_id_here
NEXT_PUBLIC_DEVAGENTS_SPEAKER_IMAGE_URL=
NEXT_PUBLIC_MATRIXO_LOGO_LIGHT_URL=
NEXT_PUBLIC_MATRIXO_LOGO_DARK_URL=
NEXT_PUBLIC_DEVAGENTS_ENTRY_PREFIX=DEVAGENTS

# Fathom AI - Meeting Summaries
FATHOM_API_KEY=your_fathom_api_key_here
