# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_auth_domain
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_storage_bucket
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Main-site Firebase overrides (recommended for production on matrixo.in)
NEXT_PUBLIC_FIREBASE_API_KEY_MAIN=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN_MAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID_MAIN=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET_MAIN=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID_MAIN=
NEXT_PUBLIC_FIREBASE_APP_ID_MAIN=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID_MAIN=

# Beta-site Firebase overrides (optional, used only when NEXT_PUBLIC_SITE_MODE=beta)
# NEXT_PUBLIC_SITE_MODE=beta
NEXT_PUBLIC_FIREBASE_API_KEY_BETA=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN_BETA=
NEXT_PUBLIC_FIREBASE_PROJECT_ID_BETA=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET_BETA=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID_BETA=
NEXT_PUBLIC_FIREBASE_APP_ID_BETA=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID_BETA=

# Firebase Auth Google Sign-in authorized domains should include:
# - beta.matrixo.in
# - matrixo.in
# - localhost

# Event branding / payment assets
NEXT_PUBLIC_DEVAGENTS_UPI_ID=your_upi_id_here
NEXT_PUBLIC_DEVAGENTS_SPEAKER_IMAGE_URL=
NEXT_PUBLIC_MATRIXO_LOGO_LIGHT_URL=
NEXT_PUBLIC_MATRIXO_LOGO_DARK_URL=
NEXT_PUBLIC_DEVAGENTS_ENTRY_PREFIX=DEVAGENTS
NEXT_PUBLIC_DEVAGENTS_GOOGLE_SCRIPT_URL=

# Resend Email Configuration
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=matriXO <onboarding@resend.dev>

# PhonePe Payment Gateway Configuration
NEXT_PUBLIC_PHONEPE_MERCHANT_ID=your_merchant_id
PHONEPE_SALT_KEY=your_salt_key
PHONEPE_SALT_INDEX=1
NEXT_PUBLIC_PHONEPE_REDIRECT_URL=https://yourdomain.com/payment/callback
PHONEPE_API_ENDPOINT=https://api-preprod.phonepe.com/apis/pg-sandbox

# SkillDNA - OpenRouter AI Configuration
# Get your key at https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key-here

# DevAgentic Automated Email System Configuration
# Google Sheets Integration (Service Account)
GOOGLE_CLIENT_EMAIL=your-service-account-email@your-project-id.iam.gserviceaccount.com
# Replace \n with actual newlines if required, but in .env usually surrounded by quotes
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour\nPrivate\nKey\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your-google-sheet-id-here

# Nodemailer / SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="matriXO Events <events@matrixo.in>"

# API Route Cron Secret (Optional, for securing the cron trigger)
CRON_SECRET=your-random-secret-string
