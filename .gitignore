# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Additional ignores for this Next.js/Node workspace

# editor
.vscode/
.history/
*.swp

# os-specific
Thumbs.db

# Windows reserved device names accidentally created by shell
# redirects (e.g. `command > out.log 2>nul` run outside cmd.exe).
# Git cannot track these paths on Windows, so keep them ignored.
nul
NUL

# build caches and outputs
dist/
.cache/

# test runners
.playwright/
test-results/

# firebase/emulators (if used)
.firebase/
functions/lib/
functions/node_modules/

# nested project clone (not part of this repo)
/matrixo-website-deployment-beta/

# ensure only example env is tracked
!.env.example
