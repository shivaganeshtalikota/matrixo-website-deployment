rules_version = '2';

// ============================================================================
// ⚠️  PRE-DEPLOY CHECKLIST — READ BEFORE `firebase deploy --only firestore:rules`
// ----------------------------------------------------------------------------
// This is the RECONCILED, authoritative ruleset. It merges:
//   (a) the security hardening + all new product collections, and
//   (b) the collections that only existed in the previously-live rules
//       (eventAttendance, events, contactSubmissions, colleges,
//        collegeRequests, countries/states/districts).
// It also FIXES a compile error in the previously-deployed rules, which
// referenced isEmployee() in the subscriptions block without defining it
// (Firestore rejects undefined-function rulesets on deploy).
//
// Hardening summary — these collections were tightened from the old
// "any authenticated user" to employee-only (isEmployee()): all portal
// collections (attendance/tasks/discussions/holidays/calendar/meetings/
// leave/systemConfig/personalTodos/pushSubscriptions/notifications),
// Employees WRITE (stops self-promotion), roles WRITE, applications
// read/update, eventAttendance, events WRITE, colleges WRITE,
// collegeRequests read/update, contactSubmissions read.
//
// BEFORE DEPLOYING, confirm no active employee relies on the legacy
// email-fallback (an Employees doc whose ID is NOT their auth uid) — such
// an account would lose portal access. isEmployee() checks
// exists(/Employees/{request.auth.uid}). Verify in the Firestore console:
// every Employees doc ID must equal its user's auth UID. Re-key mismatches
// (or provision via the Admin SDK) first.
//
// KNOWN GAP (not fixed here on purpose): the send-otp route writes an
// `EmailOTPs` collection via the client SDK. There is deliberately NO rule
// for it — a client-readable rule would let anyone read OTP codes and
// bypass verification. Move OTP issuance/verification to an Admin-SDK
// server route instead (do not add a permissive EmailOTPs rule).
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // Check if user is logged in
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the caller is a provisioned employee (doc keyed by auth uid)
    function isEmployee() {
      return isAuthenticated() &&
             exists(/databases/$(database)/documents/Employees/$(request.auth.uid));
    }

    // ================================================
    // SYSTEM CONFIG COLLECTION (Work Mode, etc.)
    // ================================================
    match /systemConfig/{configId} {
      allow read: if isEmployee();
      allow write: if isEmployee();
    }

    // ================================================
    // PERSONAL TODOS COLLECTION (employee-only)
    // ================================================
    match /personalTodos/{todoId} {
      allow read: if isEmployee();
      allow write: if isEmployee();
    }

    // ================================================
    // EMPLOYEES COLLECTION
    // Public read (team page). Writes restricted to existing employees
    // so a random authenticated user can no longer self-promote by
    // creating /Employees/{their-uid}. New employees are provisioned by
    // an existing employee/admin or via the Admin SDK.
    // ================================================
    match /Employees/{employeeId} {
      allow read: if true;
      allow write: if isEmployee();
    }

    // ================================================
    // ATTENDANCE COLLECTION
    // ================================================
    match /attendance/{attendanceId} {
      allow read: if isEmployee();
      allow write: if isEmployee();
    }

    // ================================================
    // HOLIDAYS COLLECTION
    // ================================================
    match /holidays/{holidayId} {
      allow read: if isEmployee();
      allow write: if isEmployee();
    }

    // ================================================
    // CALENDAR EVENTS COLLECTION
    // ================================================
    match /calendarEvents/{eventId} {
      allow read: if isEmployee();
      allow write: if isEmployee();
    }

    // ================================================
    // TASKS COLLECTION
    // ================================================
    match /tasks/{taskId} {
      allow read: if isEmployee();
      allow write: if isEmployee();
    }

    // ================================================
    // DISCUSSIONS COLLECTION
    // ================================================
    match /discussions/{discussionId} {
      allow read: if isEmployee();
      allow write: if isEmployee();
    }

    // ================================================
    // ACTIVITY LOGS COLLECTION
    // ================================================
    match /activityLogs/{logId} {
      allow read: if isEmployee();
      allow write: if isEmployee();
    }

    // ================================================
    // NOTIFICATIONS COLLECTION (legacy)
    // ================================================
    match /notifications/{notificationId} {
      allow read: if isEmployee();
      allow write: if isEmployee();
    }

    // ================================================
    // USER NOTIFICATIONS COLLECTION (per-employee)
    // Read/update/delete are employee-only. Public creation is retained
    // ONLY for application notifications so unauthenticated applicants can
    // notify staff of a new submission — and only with type == 'application'.
    // ================================================
    match /userNotifications/{notificationId} {
      allow read: if isEmployee();
      allow create: if isEmployee() || request.resource.data.type == 'application';
      allow update, delete: if isEmployee();
    }

    // ================================================
    // VIBECODE REGISTRATIONS COLLECTION (regular users)
    // ================================================
    match /vibecode_registrations/{registrationId} {
      // Allow authenticated users to create registrations
      allow create: if isAuthenticated();
      // Allow authenticated users to read registrations (needed for duplicate check query)
      allow read: if isAuthenticated();
      // Only admins can update or delete
      allow update, delete: if false;
    }

    // ================================================
    // USER PROFILES COLLECTION
    // ================================================
    match /UserProfiles/{userId} {
      // Anyone can read profiles (public profiles need this)
      allow read: if true;
      // Users can create their own profile (once)
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // Users can update their own profile (restricted fields enforced in app)
      allow update: if isAuthenticated() && request.auth.uid == userId;
      // Users cannot delete profiles
      allow delete: if false;
    }

    // ================================================
    // USERNAMES COLLECTION (username -> uid mapping)
    // ================================================
    match /Usernames/{usernameId} {
      // Anyone can read (needed for public profile lookups & availability checks)
      allow read: if true;
      // Authenticated users can create username mappings
      allow create: if isAuthenticated();
      // Only the owner can update their username mapping
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid;
      // Users cannot delete username mappings
      allow delete: if false;
    }

    // ================================================
    // CAREERS SYSTEM - ROLES COLLECTION
    // ================================================
    match /roles/{roleId} {
      // Anyone can read roles (public careers page reads open roles, employees can read all)
      allow read: if true;
      // Only employees can create, update, and delete roles
      allow write: if isEmployee();
    }

    // ================================================
    // CAREERS SYSTEM - APPLICATIONS COLLECTION
    // ================================================
    match /applications/{applicationId} {
      // Anyone can create an application (public apply)
      allow create: if true;
      // Only employees can read and update applications
      allow read, update: if isEmployee();
      // No one can delete applications
      allow delete: if false;
    }

    // ================================================
    // HIDDEN MEETINGS COLLECTION
    // ================================================
    match /hiddenMeetings/{meetingId} {
      allow read: if isEmployee();
      allow write: if isEmployee();
    }

    // ================================================
    // REMOVED MEETINGS COLLECTION (per-user removal)
    // ================================================
    match /removedMeetings/{meetingId} {
      allow read: if isEmployee();
      allow write: if isEmployee();
    }

    // ================================================
    // MEETING TASK STATUS COLLECTION
    // ================================================
    match /meetingTaskStatus/{taskId} {
      allow read: if isEmployee();
      allow write: if isEmployee();
    }

    // ================================================
    // PUSH SUBSCRIPTIONS COLLECTION (Web Push)
    // ================================================
    match /pushSubscriptions/{subscriptionId} {
      allow read: if isEmployee();
      allow write: if isEmployee();
    }

    // ================================================
    // MEETING NOTIFIED COLLECTION (auto-notification tracking)
    // ================================================
    match /meetingNotified/{meetingId} {
      allow read: if isEmployee();
      allow write: if isEmployee();
    }

    // ================================================
    // MEETING CUSTOM TASKS COLLECTION (admin-added tasks)
    // ================================================
    match /meetingCustomTasks/{taskId} {
      allow read: if isEmployee();
      allow write: if isEmployee();
    }

    // ================================================
    // LEAVE REQUESTS COLLECTION
    // ================================================
    match /leaveRequests/{requestId} {
      allow read: if isEmployee();
      allow write: if isEmployee();
    }

    // ================================================
    // GROWGRID PROGRESS COLLECTION (owner-only)
    // Doc id == user uid. Only the owner may read or write their
    // learning progress. XP/level are derived client-side but are not
    // security-sensitive (no entitlement is granted from this doc).
    // ================================================
    match /growgrid_progress/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow create, update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if false;
    }

    // ================================================
    // SUBSCRIPTIONS COLLECTION (premium entitlements)
    // Manual-UPI + verification model:
    //   - a user may CREATE a claim for THEMSELVES, and only in the
    //     'pending' state (they cannot self-grant 'active')
    //   - a user may READ their own subscriptions
    //   - only employees may update (verify -> active/rejected)
    //   - no deletes (audit trail)
    // ================================================
    match /subscriptions/{subId} {
      // Owner reads their own; employees read all (to verify payments).
      allow read: if isEmployee()
                  || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.status == 'pending';
      allow update, delete: if isEmployee();
    }

    // ================================================
    // PLAYCRED CREDENTIALS COLLECTION
    // Public read so anyone can verify a credential via its link.
    // A user may create only their OWN credential (userId match) and
    // credentials are immutable (no update/delete) so the integrity
    // hash always reflects the issued record.
    // NOTE: issuance is currently client-side; the documented hardening
    // is to move minting to an Admin-SDK server route that validates
    // GrowGrid completion and signs the credential.
    // ================================================
    match /playcred_credentials/{credId} {
      allow read: if true;
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ================================================
    // MENTORMATRIX SESSIONS COLLECTION
    // A user creates & reads their own session requests. Employees
    // (and mentors, admin-side) may update status to confirm/complete.
    // Users may cancel their own request; no hard deletes (audit).
    // ================================================
    match /mentormatrix_sessions/{sessionId} {
      allow read: if isEmployee()
                  || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.status == 'requested';
      // Owner may only move their own session to 'cancelled'; employees
      // may set any status.
      allow update: if isEmployee()
                    || (isAuthenticated()
                        && resource.data.userId == request.auth.uid
                        && request.resource.data.status == 'cancelled');
      allow delete: if false;
    }

    // ================================================
    // EVENT TICKETS COLLECTION (surfaced in the user dashboard)
    // Owner reads their own tickets; employees read all (check-in/admin).
    // A user may create their own ticket; status changes (confirm/cancel)
    // are employee-side; no deletes (audit).
    // ================================================
    match /event_tickets/{ticketId} {
      allow read: if isEmployee()
                  || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;
      allow update: if isEmployee();
      allow delete: if false;
    }

    // ================================================
    // IMPACTVAULT ACCESS COLLECTION (RBAC for the analytics dashboard)
    // A user may read their OWN access record (to resolve their role);
    // only employees/admins may grant or change access.
    //
    // ARCHITECTURE NOTE: institution-wide analytics aggregate many
    // students' skillDNA_users docs, which are (correctly) owner-only for
    // privacy. Client-side aggregation therefore CANNOT read other
    // students' SkillDNA. Full ImpactVault aggregation must run
    // server-side via the Admin SDK (privileged, privacy-preserving) —
    // do NOT relax the skillDNA_users rules to enable it.
    // ================================================
    match /impactvault_access/{userId} {
      allow read: if isEmployee() || (isAuthenticated() && request.auth.uid == userId);
      allow write: if isEmployee();
    }

    // ================================================
    // EVENT ATTENDANCE COLLECTION (QR scanner check-in) — portal-only
    // ================================================
    match /eventAttendance/{attendanceId} {
      allow read: if isEmployee();
      allow write: if isEmployee();
    }

    // ================================================
    // EVENTS COLLECTION (portal event management / QR event list)
    // Authenticated read (app may list); only employees manage.
    // ================================================
    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow write: if isEmployee();
    }

    // ================================================
    // CONTACT SUBMISSIONS COLLECTION
    // Public create (contact form); only staff read; immutable.
    // ================================================
    match /contactSubmissions/{submissionId} {
      allow create: if true;
      allow read: if isEmployee();
      allow update, delete: if false;
    }

    // ================================================
    // COLLEGES COLLECTION (approved directory)
    // Public read (registration dropdown); only staff add/edit so the
    // directory can't be polluted by arbitrary users.
    // ================================================
    match /colleges/{collegeId} {
      allow read: if true;
      allow write: if isEmployee();
    }

    // ================================================
    // COLLEGE REQUESTS COLLECTION
    // Any signed-in user may submit a request; staff review/approve.
    // ================================================
    match /collegeRequests/{requestId} {
      allow create: if isAuthenticated();
      allow read, update: if isEmployee();
      allow delete: if false;
    }

    // ================================================
    // LOCATION REFERENCE DATA (public read, no client write)
    // Seeded via the Admin SDK scripts; never written from the client.
    // ================================================
    match /countries/{countryId} { allow read: if true; allow write: if false; }
    match /states/{stateId}      { allow read: if true; allow write: if false; }
    match /districts/{districtId} { allow read: if true; allow write: if false; }

    // ================================================
    // SKILLDNA USERS COLLECTION
    // ================================================
    match /skillDNA_users/{userId} {
      // Users can only read their own SkillDNA profile
      allow read: if isAuthenticated() && request.auth.uid == userId;
      // Users can create their own SkillDNA profile
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // Users can update their own profile
      allow update: if isAuthenticated() && request.auth.uid == userId;
      // Users cannot delete SkillDNA profiles
      allow delete: if false;

      // Version history subcollection
      match /versions/{versionId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow create: if isAuthenticated() && request.auth.uid == userId;
        allow update, delete: if false;
      }

      // Assessment results subcollection
      match /assessments/{assessmentId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow create: if isAuthenticated() && request.auth.uid == userId;
        allow update, delete: if false;
      }

      // Activity log subcollection
      match /activityLog/{logId} {
        allow read: if isAuthenticated() && request.auth.uid == userId;
        allow create: if isAuthenticated() && request.auth.uid == userId;
        allow update, delete: if false;
      }
    }
  }
}
